<script>
// ===== DATA =====
const DEFAULT = {
  name: 'Your Name',
  sub: 'Creative',
  tagline: 'デザインとコードで世界をつくる。クリエイターとしての足跡をここに。',
  bio: 'ここにあなたの自己紹介を書きましょう。経歴・得意分野・制作への想いなど、あなたらしい言葉で伝えてください。',
  skills: 'UI Design, Photography, Web Development',
  photo: '',
  email: 'your@email.com',
  sns: '@yourhandle',
  contactDesc: 'お仕事のご依頼・ご相談など、お気軽にお問い合わせください。2〜3営業日以内にご返信いたします。',
  sitename: 'Portfolio',
  password: 'admin123',
  works: [
    {id:1, title:'Project Alpha', cat:'Web Design', desc:'Webサイトのデザイン・実装プロジェクト。', img:''},
    {id:2, title:'Photo Series', cat:'Photography', desc:'都市の光と影を切り取った写真シリーズ。', img:''},
    {id:3, title:'Brand Identity', cat:'Branding', desc:'スタートアップのブランドアイデンティティ制作。', img:''},
  ],
  news: [
    {id:1, title:'ポートフォリオサイトをリニューアルしました', body:'新しいデザインのサイトを公開しました。', tag:'News', date:'2025.01.15'},
    {id:2, title:'新しい作品を追加しました', body:'ギャラリーに最新プロジェクトを追加しました。', tag:'Update', date:'2025.01.10'},
  ]
};

function loadData(){
  try{ return {...DEFAULT, ...JSON.parse(localStorage.getItem('pf_data')||'{}')} }
  catch(e){ return {...DEFAULT} }
}
function saveData(d){ localStorage.setItem('pf_data', JSON.stringify(d)) }

let D = loadData();

// ===== RENDER =====
function renderAll(){
  // hero
  document.getElementById('nav-logo').textContent = D.sitename||'Portfolio';
  document.getElementById('footer-logo').textContent = D.sitename||'Portfolio';
  document.getElementById('hero-name-main').textContent = D.name||'Your Name';
  document.getElementById('hero-sub').textContent = D.sub||'Creative';
  document.getElementById('hero-tagline').textContent = D.tagline;
  document.title = (D.sitename||'Portfolio') + ' | ' + (D.name||'');

  // about
  document.getElementById('about-name').textContent = D.name||'Your Name';
  document.getElementById('about-bio').textContent = D.bio;
  const sw = document.getElementById('about-skills-wrap');
  sw.innerHTML = (D.skills||'').split(',').map(s=>s.trim()).filter(Boolean)
    .map(s=>`<span class="skill-tag">${s}</span>`).join('');
  const pw = document.getElementById('about-img-wrap');
  if(D.photo){
    pw.innerHTML = `<img src="${D.photo}" alt="profile" style="width:100%;height:100%;object-fit:cover;position:absolute;inset:0"><span class="placeholder-text" id="about-img-placeholder" style="display:none">Photo</span>`;
  } else {
    pw.innerHTML = `<span class="placeholder-text" id="about-img-placeholder">Photo</span>`;
  }

  // contact
  document.getElementById('contact-email').textContent = D.email||'';
  document.getElementById('contact-sns').textContent = D.sns||'';
  document.getElementById('contact-desc').textContent = D.contactDesc||'';
  document.getElementById('footer-name').textContent = D.name||'Your Name';

  renderWorks();
  renderNews();
}

function renderWorks(){
  const g = document.getElementById('works-grid');
  g.innerHTML = '';
  (D.works||[]).forEach(w=>{
    const div = document.createElement('div');
    div.className = 'work-card';
    div.onclick = ()=>openModal(w);
    div.innerHTML = w.img
      ? `<img class="work-card-img" src="${w.img}" alt="${w.title}">`
      : `<div class="work-card-placeholder">${w.title}</div>`;
    div.innerHTML += `<div class="work-card-overlay"><div class="work-title">${w.title}</div><div class="work-cat">${w.cat}</div></div>`;
    g.appendChild(div);
  });
  if(!(D.works||[]).length) g.innerHTML = `<p style="color:var(--muted);font-size:13px;padding:20px 0">まだ作品がありません。管理パネルから追加してください。</p>`;

  // admin list
  const al = document.getElementById('works-admin-list');
  if(!al) return;
  al.innerHTML = '';
  (D.works||[]).forEach(w=>{
    const div = document.createElement('div');
    div.className = 'admin-list-item';
    div.innerHTML = `<div><div class="admin-list-item-text">${w.title}</div><div class="admin-list-item-sub">${w.cat}</div></div>
    <div class="admin-item-actions"><button class="admin-item-btn del" onclick="deleteWork(${w.id})">削除</button></div>`;
    al.appendChild(div);
  });
}

function renderNews(){
  const nl = document.getElementById('news-list');
  nl.innerHTML = '';
  (D.news||[]).forEach(n=>{
    const div = document.createElement('div');
    div.className = 'news-item';
    div.innerHTML = `<div class="news-date">${n.date}</div>
    <div><div class="news-title">${n.title}</div>
    <div class="news-body">${n.body}</div>
    ${n.tag?`<span class="news-tag">${n.tag}</span>`:''}</div>`;
    nl.appendChild(div);
  });
  if(!(D.news||[]).length) nl.innerHTML = `<p style="color:var(--muted);font-size:13px;padding:20px 0">まだお知らせがありません。</p>`;

  const al = document.getElementById('news-admin-list');
  if(!al) return;
  al.innerHTML = '';
  (D.news||[]).forEach(n=>{
    const div = document.createElement('div');
    div.className = 'admin-list-item';
    div.innerHTML = `<div><div class="admin-list-item-text">${n.title}</div><div class="admin-list-item-sub">${n.date}</div></div>
    <div class="admin-item-actions"><button class="admin-item-btn del" onclick="deleteNews(${n.id})">削除</button></div>`;
    al.appendChild(div);
  });
}

// ===== MODAL =====
function openModal(w){
  document.getElementById('modal-title').textContent = w.title;
  document.getElementById('modal-cat').textContent = w.cat;
  document.getElementById('modal-desc').textContent = w.desc;
  const iw = document.getElementById('modal-img-wrap');
  iw.innerHTML = w.img ? `<img class="modal-img" src="${w.img}" alt="${w.title}">` : '';
  document.getElementById('modal-overlay').classList.add('open');
}
function closeModal(e){ if(e.target===e.currentTarget) document.getElementById('modal-overlay').classList.remove('open') }
function closeModalBtn(){ document.getElementById('modal-overlay').classList.remove('open') }

// ===== LOGIN =====
function openLogin(){ document.getElementById('login-overlay').classList.add('open'); }
function doLogin(){
  const pw = document.getElementById('login-pw').value;
  if(pw === (D.password||'admin123')){
    document.getElementById('login-overlay').classList.remove('open');
    openAdmin();
    document.getElementById('login-pw').value='';
    document.getElementById('login-err').style.display='none';
  } else {
    document.getElementById('login-err').style.display='block';
  }
}
document.getElementById('login-pw').addEventListener('keydown',e=>{ if(e.key==='Enter') doLogin(); });

// ===== ADMIN =====
function openAdmin(){
  document.getElementById('admin-overlay').classList.add('open');
  fillAdminForms();
}
function closeAdmin(){ document.getElementById('admin-overlay').classList.remove('open') }

function fillAdminForms(){
  document.getElementById('s-name').value = D.name||'';
  document.getElementById('s-sub').value = D.sub||'';
  document.getElementById('s-tagline').value = D.tagline||'';
  document.getElementById('s-bio').value = D.bio||'';
  document.getElementById('s-skills').value = D.skills||'';
  document.getElementById('s-photo').value = D.photo||'';
  document.getElementById('s-email').value = D.email||'';
  document.getElementById('s-sns').value = D.sns||'';
  document.getElementById('s-contact-desc').value = D.contactDesc||'';
  document.getElementById('s-sitename').value = D.sitename||'Portfolio';
  renderWorks(); renderNews();
}

function switchTab(name){
  document.querySelectorAll('.admin-tab').forEach(t=>t.classList.remove('active'));
  document.querySelectorAll('.admin-section').forEach(s=>s.classList.remove('active'));
  event.target.classList.add('active');
  document.getElementById('tab-'+name).classList.add('active');
}

function showMsg(id){
  const el = document.getElementById(id);
  el.style.display='inline';
  setTimeout(()=>el.style.display='none', 2000);
}

function saveProfile(){
  D.name = document.getElementById('s-name').value;
  D.sub = document.getElementById('s-sub').value;
  D.tagline = document.getElementById('s-tagline').value;
  D.bio = document.getElementById('s-bio').value;
  D.skills = document.getElementById('s-skills').value;
  D.photo = document.getElementById('s-photo').value;
  D.email = document.getElementById('s-email').value;
  D.sns = document.getElementById('s-sns').value;
  D.contactDesc = document.getElementById('s-contact-desc').value;
  saveData(D); renderAll(); showMsg('msg-profile');
}

function addWork(){
  const t = document.getElementById('w-title').value.trim();
  if(!t) return;
  D.works = D.works||[];
  D.works.unshift({
    id: Date.now(),
    title: t,
    cat: document.getElementById('w-cat').value||'Work',
    desc: document.getElementById('w-desc').value,
    img: document.getElementById('w-img').value
  });
  document.getElementById('w-title').value='';
  document.getElementById('w-cat').value='';
  document.getElementById('w-desc').value='';
  document.getElementById('w-img').value='';
  saveData(D); renderWorks(); showMsg('msg-works');
}
function deleteWork(id){
  D.works = (D.works||[]).filter(w=>w.id!==id);
  saveData(D); renderWorks();
}

function addNews(){
  const t = document.getElementById('n-title').value.trim();
  if(!t) return;
  D.news = D.news||[];
  const now = new Date();
  const date = `${now.getFullYear()}.${String(now.getMonth()+1).padStart(2,'0')}.${String(now.getDate()).padStart(2,'0')}`;
  D.news.unshift({
    id: Date.now(),
    title: t,
    body: document.getElementById('n-body').value,
    tag: document.getElementById('n-tag').value,
    date
  });
  document.getElementById('n-title').value='';
  document.getElementById('n-body').value='';
  document.getElementById('n-tag').value='';
  saveData(D); renderNews(); showMsg('msg-news');
}
function deleteNews(id){
  D.news = (D.news||[]).filter(n=>n.id!==id);
  saveData(D); renderNews();
}

function saveSettings(){
  D.sitename = document.getElementById('s-sitename').value||'Portfolio';
  const np = document.getElementById('s-newpw').value;
  if(np) D.password = np;
  document.getElementById('s-newpw').value='';
  saveData(D); renderAll(); showMsg('msg-settings');
}

// ===== CONTACT FORM =====
function submitForm(e){
  e.preventDefault();
  document.getElementById('form-msg').style.display='block';
  e.target.reset();
  setTimeout(()=>document.getElementById('form-msg').style.display='none', 4000);
}

// ===== INIT =====
renderAll();
</script>

